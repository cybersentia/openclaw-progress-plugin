{
  "id": "openclaw-progress-plugin",
  "name": "OpenClaw Progress Plugin",
  "description": "Stream task progress to chat clients with Feishu-first adapter support.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "feishu": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "appId": { "type": "string" },
          "appSecret": { "type": "string" },
          "baseUrl": { "type": "string", "default": "https://open.feishu.cn" },
          "defaultConversationId": { "type": "string" },
          "timeoutMs": { "type": "number", "default": 10000 },
          "stateFile": { "type": "string", "default": ".openclaw-progress-plugin-state.json" },
          "runMessageTtlMs": { "type": "number", "default": 1800000 }
        },
        "additionalProperties": false
      },
      "throttle": {
        "type": "object",
        "properties": {
          "minEmitIntervalMs": { "type": "number", "default": 1000 },
          "heartbeatIntervalMs": { "type": "number", "default": 5000 }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
